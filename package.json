{
  "name": "altftool",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11"
  },
  "workspaces": [
    "altftoolweb",
    "altftoolwebadmin",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:web && npm run build:admin",
    "build:web": "npm --prefix altftoolweb run build",
    "build:admin": "npm --prefix altftoolwebadmin run build",
    "dev:web": "npm --prefix altftoolweb run dev -- -p 3002",
    "dev:admin": "npm --prefix altftoolwebadmin run dev -- -p 3001",
    "start:web": "npm --prefix altftoolweb run start -- -p 3002",
    "start:admin": "npm --prefix altftoolwebadmin run start -- -p 3001",
    "lint:web": "npm --prefix altftoolweb run lint -- --quiet",
    "lint:web:budget": "node scripts/check-web-lint-budget.mjs",
    "audit": "npm run audit:web && npm run audit:admin",
    "audit:web": "npm --prefix altftoolweb audit --audit-level=moderate",
    "audit:admin": "npm --prefix altftoolwebadmin audit --audit-level=moderate",
    "routes:check": "node scripts/check-routes.mjs",
    "firebase:check": "node scripts/check-firebase-contracts.mjs",
    "firebase:live-check": "node scripts/check-firebase-live-data.mjs",
    "test:smoke": "playwright test tests/smoke.spec.mjs",
    "test:routes": "playwright test tests/route-audit.spec.mjs",
    "test:visual": "NEXT_PUBLIC_USE_MOCK=true playwright test tests/visual.spec.mjs",
    "test:visual:update": "NEXT_PUBLIC_USE_MOCK=true playwright test tests/visual.spec.mjs --update-snapshots",
    "test:security": "playwright test tests/security.spec.mjs",
    "test:lighthouse": "playwright test tests/lighthouse.spec.mjs",
    "validate": "npm run lint:web && npm run lint:web:budget && npm run routes:check && npm run firebase:check && npm run audit && npm run build && npm run test:smoke",
    "validate:full": "npm run validate && npm run test:routes",
    "validate:release": "npm run validate:full && npm run firebase:live-check && npm run test:security && npm run test:visual && npm run test:lighthouse"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.2.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4"
  },
  "overrides": {
    "postcss": "^8.5.14",
    "next": {
      "postcss": "^8.5.14"
    }
  }
}
